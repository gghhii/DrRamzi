@model IEnumerable<DrAshrafMellouli.Models.Treatment>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Gestion des Traitements";
}

<div class="admin-header">
    <h1 class="admin-title">Traitements</h1>
    <a asp-action="CreateTreatment" class="btn-luxury">Nouveau Traitement</a>
</div>

<div class="admin-card">
    <table class="table-lux">
        <thead>
            <tr>
                <th>Visuel</th>
                <th>Titre</th>
                <th>Catégorie</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <img src="@item.ImageUrl" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px; border: 1px solid rgba(255,255,255,0.1);" onerror="this.src='/images/placeholder.jpg'" />
                    </td>
                    <td style="font-weight: 600;">@item.Title</td>
                    <td><span class="badge-cat">@item.Category</span></td>
                    <td style="color: var(--admin-text-muted); font-size: 0.85rem; max-width: 400px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                        @item.Description
                    </td>
                    <td>
                        <a asp-action="EditTreatment" asp-route-id="@item.Id" class="action-link">Modifier</a>
                        <form asp-action="DeleteTreatment" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce traitement ?');">
                            <button type="submit" class="delete-btn">Supprimer</button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" style="text-align: center; padding: 50px; color: var(--admin-text-muted)">
                        Aucun traitement trouvé.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
