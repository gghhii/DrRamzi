@model DrAshrafMellouli.Models.Testimonial
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Ajouter un Avis Patient";
}

<div class="admin-header">
    <h1 class="admin-title">@ViewData["Title"]</h1>
    <a asp-action="ManageTestimonials" class="action-link">← Retour à la liste</a>
</div>

<div class="admin-card" style="max-width: 600px;">
    <form asp-action="CreateTestimonial" method="post">
        
        <div class="form-group">
            <label asp-for="Name" class="form-label">Nom du Patient</label>
            <input asp-for="Name" class="form-control" placeholder="ex: Sarah B." />
            <span asp-validation-for="Name" style="color: #ff4d4d; font-size: 0.8rem;"></span>
        </div>

        <div class="form-group">
            <label asp-for="Procedure" class="form-label">Procédure Réalisée</label>
            <input asp-for="Procedure" class="form-control" placeholder="ex: Hydrafacial & Injection Lèvres" />
            <span asp-validation-for="Procedure" style="color: #ff4d4d; font-size: 0.8rem;"></span>
        </div>

        <div class="form-group">
            <label asp-for="Content" class="form-label">Témoignage</label>
            <textarea asp-for="Content" class="form-control" rows="5" placeholder="Le texte de l'avis..."></textarea>
            <span asp-validation-for="Content" style="color: #ff4d4d; font-size: 0.8rem;"></span>
        </div>

        <div class="form-group">
            <label asp-for="Rating" class="form-label">Note (1 à 5)</label>
            <select asp-for="Rating" class="form-control">
                <option value="5">5 Étoiles ★★★★★</option>
                <option value="4">4 Étoiles ★★★★</option>
                <option value="3">3 Étoiles ★★★</option>
                <option value="2">2 Étoiles ★★</option>
                <option value="1">1 Étoile ★</option>
            </select>
        </div>

        <div class="form-group">
            <label class="checkbox-container">
                <input type="checkbox" asp-for="IsFeatured">
                <span class="checkmark"></span>
                Mettre en avant sur la page d'accueil
            </label>
        </div>

        <div style="margin-top: 40px;">
            <button type="submit" class="btn-luxury">Enregistrer l'Avis</button>
        </div>
    </form>
</div>

<style>
.checkbox-container { display: flex; align-items: center; gap: 10px; cursor: pointer; color: var(--admin-text-muted); font-size: 0.9rem; margin-top: 20px; }
.checkbox-container input { display: none; }
.checkmark { width: 18px; height: 18px; border: 2px solid var(--admin-accent); border-radius: 4px; position: relative; }
.checkbox-container input:checked + .checkmark::after { content: '✓'; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: var(--admin-accent); font-weight: bold; }
</style>
