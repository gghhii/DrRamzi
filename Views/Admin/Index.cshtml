@model dynamic
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Tableau de Bord";
}

<div class="admin-header">
    <h1 class="admin-title">Bienvenue, Professeur Moatemri</h1>
    <div class="admin-date">@DateTime.Now.ToString("dd MMMM yyyy")</div>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px;">
    <!-- Stats Cards -->
    <div class="admin-card" style="display: flex; align-items: center; gap: 20px;">
        <div style="background: rgba(197, 160, 89, 0.1); padding: 20px; border-radius: 12px; color: var(--admin-accent)">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        </div>
        <div>
            <div style="color: var(--admin-text-muted); font-size: 0.9rem; margin-bottom: 5px;">Traitements</div>
            <div style="font-size: 1.8rem; font-weight: 700;">@ViewBag.TreatmentsCount</div>
        </div>
    </div>

    <div class="admin-card" style="display: flex; align-items: center; gap: 20px;">
        <div style="background: rgba(197, 160, 89, 0.1); padding: 20px; border-radius: 12px; color: var(--admin-accent)">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div>
            <div style="color: var(--admin-text-muted); font-size: 0.9rem; margin-bottom: 5px;">Résultats</div>
            <div style="font-size: 1.8rem; font-weight: 700;">@ViewBag.ResultsCount</div>
        </div>
    </div>

    <div class="admin-card" style="display: flex; align-items: center; gap: 20px;">
        <div style="background: rgba(197, 160, 89, 0.1); padding: 20px; border-radius: 12px; color: var(--admin-accent)">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg>
        </div>
        <div>
            <div style="color: var(--admin-text-muted); font-size: 0.9rem; margin-bottom: 5px;">Articles</div>
            <div style="font-size: 1.8rem; font-weight: 700;">@ViewBag.ArticlesCount</div>
        </div>
    </div>
</div>

<div style="margin-top: 50px;">
    <h2 style="font-family: 'Outfit', sans-serif; margin-bottom:30px;">Actions Rapides</h2>
    <div style="display: flex; gap: 20px;">
        <a asp-action="CreateTreatment" class="btn-luxury">Ajouter un Traitement</a>
        <a asp-action="CreateResult" class="btn-luxury">Ajouter un Résultat</a>
        <a asp-action="CreateArticle" class="btn-luxury">Publier un Article</a>
    </div>
</div>

<div class="admin-card" style="margin-top: 50px;">
    <h3 style="margin-top:0;">Dernières Mises à Jour</h3>
    <p style="color: var(--admin-text-muted)">Le système est prêt. Vous pouvez maintenant gérer votre contenu de manière dynamique.</p>
</div>
