@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login - Dr Ramzi Moatemri</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --color-gold: #ffffff;
            --color-gold-bright: #e5d5b7;
            --color-dark: #070707;
            --font-serif: 'Playfair Display', serif;
            --font-sans: 'Inter', sans-serif;
            --glass: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: var(--color-dark);
            color: #fff;
            font-family: var(--font-sans);
            height: 100vh;
            width: 100vw;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        /* --- STUNNING BACKGROUND SYSTEM --- */
        .login-universe {
            position: fixed;
            inset: 0;
            z-index: 1;
            background: radial-gradient(circle at 50% 50%, #151515 0%, #070707 100%);
        }

        .ambient-light {
            position: absolute;
            width: 800px;
            height: 800px;
            background: radial-gradient(circle, var(--color-gold) 0%, transparent 70%);
            filter: blur(150px);
            opacity: 0.08;
            pointer-events: none;
            animation: pulseLight 15s infinite alternate ease-in-out;
        }

        @@keyframes pulseLight {
            0% { transform: translate(-10%, -10%) scale(1); opacity: 0.05; }
            100% { transform: translate(5%, 5%) scale(1.2); opacity: 0.1; }
        }

        .gold-dust {
            position: absolute;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
            opacity: 0.03;
            mix-blend-mode: overlay;
            pointer-events: none;
        }

        /* --- LOGO MOTIF BACKDROP --- */
        .backdrop-motif {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 60vh;
            height: 60vh;
            opacity: 0.02;
            pointer-events: none;
        }

        /* --- MASTER LOGIN CONTAINER --- */
        .login-master-container {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 460px;
            padding: 20px;
        }

        .login-card {
            background: var(--glass);
            backdrop-filter: blur(40px) saturate(180%);
            -webkit-backdrop-filter: blur(40px) saturate(180%);
            border: 1px solid var(--glass-border);
            border-radius: 2px;
            padding: 4rem 3.5rem;
            box-shadow: 0 50px 100px rgba(0,0,0,0.8), inset 0 0 0 1px rgba(255,255,255,0.05);
            animation: cardReveal 1.5s cubic-bezier(0.16, 1, 0.3, 1) both;
            position: relative;
            overflow: hidden;
        }

        .login-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
            animation: shineTop 4s infinite linear;
        }

        @@keyframes shineTop {
            0% { left: -100%; }
            50%, 100% { left: 100%; }
        }

        @@keyframes cardReveal {
            from { opacity: 0; transform: translateY(60px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .login-header {
            text-align: center;
            margin-bottom: 4rem;
        }

        .login-title {
            font-family: var(--font-serif);
            font-size: 2.2rem;
            letter-spacing: 0.15em;
            color: #fff;
            margin-bottom: 0.5rem;
        }

        .login-title em {
            font-style: italic;
            font-weight: 300;
            color: var(--color-gold);
        }

        .login-subtitle {
            font-size: 0.6rem;
            letter-spacing: 0.5em;
            color: rgba(255,255,255,0.3);
            text-transform: uppercase;
            display: block;
        }

        /* --- LUXURY FORM --- */
        .form-group {
            margin-bottom: 2.5rem;
            position: relative;
        }

        .label-minimal {
            display: block;
            font-size: 0.6rem;
            letter-spacing: 0.2em;
            color: var(--color-gold);
            margin-bottom: 1rem;
            text-transform: uppercase;
            font-weight: 600;
        }

        .input-wrapper {
            position: relative;
        }

        .input-lux {
            width: 100%;
            background: rgba(255, 255, 255, 0.02);
            border: none;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding: 1.2rem 0;
            color: #fff;
            font-size: 1rem;
            font-family: var(--font-sans);
            transition: all 0.5s ease;
            outline: none;
        }

        .input-lux:focus {
            border-bottom-color: var(--color-gold);
            background: rgba(255, 255, 255, 0.04);
            padding-left: 1rem;
        }

        .input-focus-line {
            position: absolute;
            bottom: 0;
            left: 50%;
            width: 0;
            height: 1px;
            background: var(--color-gold);
            transition: all 0.5s ease;
            transform: translateX(-50%);
        }

        .input-lux:focus + .input-focus-line {
            width: 100%;
        }

        .btn-submit-container {
            margin-top: 4rem;
        }

        .btn-lux-submit {
            width: 100%;
            background: #fff;
            color: #000;
            border: 1px solid #fff;
            padding: 1.2rem;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
            overflow: hidden;
        }

        .btn-lux-submit:hover {
            background: var(--color-gold);
            border-color: var(--color-gold);
            color: #fff;
            letter-spacing: 0.35em;
        }

        .error-overlay {
            margin-bottom: 2.5rem;
            padding: 1rem;
            border-left: 2px solid #ff4444;
            background: rgba(255, 68, 68, 0.05);
            font-size: 0.75rem;
            color: #ff9999;
            animation: errorShake 0.4s ease;
        }

        @@keyframes errorShake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }

        .footer-links {
            margin-top: 3rem;
            text-align: center;
        }

        .link-secondary {
            font-size: 0.65rem;
            color: rgba(255,255,255,0.4);
            text-decoration: none;
            letter-spacing: 0.1em;
            transition: color 0.3s ease;
            text-transform: uppercase;
        }

        .link-secondary:hover {
            color: var(--color-gold);
        }

        /* --- DECORATIVE CROSSHAIRS --- */
        .crosshair {
            position: absolute;
            width: 20px;
            height: 20px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            pointer-events: none;
        }
        .ch-tl { top: 10px; left: 10px; border-right: none; border-bottom: none; }
        .ch-br { bottom: 10px; right: 10px; border-left: none; border-top: none; }

    </style>
</head>
<body>
    <div class="login-universe">
        <div class="ambient-light"></div>
        <div class="gold-dust"></div>
        
        <div class="backdrop-motif">
            <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="0.2">
                <circle cx="50" cy="50" r="48" opacity="0.5"/>
                <path d="M42 20 C55 18, 68 25, 68 40 C68 55, 60 58, 55 65 C50 72, 52 85, 52 85 M35 25 C25 35, 25 65, 45 80" />
            </svg>
        </div>
    </div>

    <div class="login-master-container">
        <main class="login-card">
            <div class="crosshair ch-tl"></div>
            <div class="crosshair ch-br"></div>

            <header class="login-header">
                <h1 class="login-title">DR RAMZI <em>MOATEMRI</em></h1>
                <span class="login-subtitle">Interface Administrative</span>
            </header>

            @if (ViewBag.Error != null)
            {
                <div class="error-overlay">
                    @ViewBag.Error
                </div>
            }

            <form asp-action="Login" method="post">
                <div class="form-group">
                    <label class="label-minimal">Clé d'accès confidentielle</label>
                    <div class="input-wrapper">
                        <input type="password" name="password" class="input-lux" placeholder="••••••••••••" required autofocus />
                        <div class="input-focus-line"></div>
                    </div>
                </div>

                <div class="btn-submit-container">
                    <button type="submit" class="btn-lux-submit">VALIDER L'ACCÈS</button>
                </div>
            </form>

            <div class="footer-links">
                <a href="/" class="link-secondary">Retour à l'expérience publique</a>
            </div>
        </main>
    </div>

    <script>
        // Subtle Mouse parallax for ambient light
        document.body.addEventListener('mousemove', e => {
            const light = document.querySelector('.ambient-light');
            const x = e.clientX / window.innerWidth;
            const y = e.clientY / window.innerHeight;
            
            light.style.transform = `translate(${x * 50 - 25}px, ${y * 50 - 25}px)`;
        });
    </script>
</body>
</html>
