<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --admin-primary: #1a1a1a;
            --admin-secondary: #2d2d2d;
            --admin-accent: #c5a059;
            --admin-text: #ffffff;
            --admin-text-muted: #a0a0a0;
            --admin-bg: #0f0f0f;
            --admin-card-bg: #1e1e1e;
        }

        body {
            background: var(--admin-bg);
            color: var(--admin-text);
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
            display: flex;
            min-height: 100vh;
        }

        .admin-sidebar {
            width: 280px;
            background: var(--admin-primary);
            border-right: 1px solid rgba(255,255,255,0.05);
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
        }

        .admin-logo {
            padding: 40px;
            font-family: 'Outfit', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: 1px;
            color: var(--admin-accent);
            text-decoration: none;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .admin-nav {
            padding: 20px 0;
            flex-grow: 1;
        }

        .admin-nav-link {
            display: flex;
            align-items: center;
            padding: 15px 40px;
            color: var(--admin-text-muted);
            text-decoration: none;
            transition: all 0.3s ease;
            font-weight: 500;
        }

        .admin-nav-link:hover, .admin-nav-link.active {
            color: var(--admin-text);
            background: rgba(197, 160, 89, 0.1);
            border-left: 4px solid var(--admin-accent);
        }

        .admin-nav-link svg {
            margin-right: 15px;
            width: 20px;
            height: 20px;
        }

        .admin-main {
            flex-grow: 1;
            margin-left: 280px;
            padding: 60px;
        }

        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 50px;
        }

        .admin-title {
            font-family: 'Outfit', sans-serif;
            font-size: 2.5rem;
            margin: 0;
        }

        .admin-card {
            background: var(--admin-card-bg);
            border-radius: 12px;
            padding: 30px;
            border: 1px solid rgba(255,255,255,0.05);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .btn-luxury {
            background: var(--admin-accent);
            color: #000;
            border: none;
            padding: 12px 25px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            transition: transform 0.2s ease;
        }

        .btn-luxury:hover {
            transform: translateY(-2px);
            background: #d4b16a;
        }

        .table-lux {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .table-lux th {
            text-align: left;
            padding: 15px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            color: var(--admin-text-muted);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.8rem;
        }

        .table-lux td {
            padding: 15px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .badge-cat {
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 700;
            background: rgba(197, 160, 89, 0.2);
            color: var(--admin-accent);
        }

        .action-link {
            color: var(--admin-accent);
            text-decoration: none;
            margin-right: 15px;
            font-size: 0.9rem;
        }

        .delete-btn {
            color: #ff4d4d;
            background: none;
            border: none;
            padding: 0;
            cursor: pointer;
            font-size: 0.9rem;
        }

        /* Form styling */
        .form-group {
            margin-bottom: 25px;
        }
        .form-label {
            display: block;
            margin-bottom: 10px;
            color: var(--admin-text-muted);
            font-weight: 500;
        }
        .form-control {
            width: 100%;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 6px;
            padding: 12px 15px;
            color: #fff;
            font-family: 'Inter', sans-serif;
        }
        .form-control:focus {
            outline: none;
            border-color: var(--admin-accent);
        }
        textarea.form-control {
            min-height: 150px;
        }
    </style>
</head>
<body>
    <!-- CUSTOM PRO CURSOR -->
    <div class="pro-cursor" id="proCursor"></div>
    <div class="pro-cursor-follower" id="proCursorFollower"></div>

    <aside class="admin-sidebar">
        <a href="/" class="admin-logo">PR. MOATEMRI</a>
        <nav class="admin-nav">
            <a asp-controller="Admin" asp-action="Index" class="admin-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                Dashboard
            </a>
            <a asp-controller="Admin" asp-action="Treatments" class="admin-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Treatments" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                Traitements
            </a>
            <a asp-controller="Admin" asp-action="Results" class="admin-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Results" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                Résultats
            </a>
            <a asp-controller="Admin" asp-action="Articles" class="admin-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Articles" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg>
                Journal
            </a>
            <a asp-controller="Admin" asp-action="ManageTestimonials" class="admin-nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Testimonial") == true ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                Témoignages
            </a>
            <a asp-controller="Admin" asp-action="Appointments" class="admin-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Appointments" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                Rendez-vous
            </a>
        </nav>
        <div style="padding: 20px 40px; border-top: 1px solid rgba(255,255,255,0.05)">
             <a asp-controller="Home" asp-action="Index" class="admin-nav-link" style="padding: 10px 0; color: var(--admin-text-muted); font-size: 0.9rem;">
                ← Retour au site
             </a>
             <a asp-controller="Admin" asp-action="Logout" class="admin-nav-link" style="padding: 10px 0; color: #ff6b6b; font-size: 0.9rem;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 10px;"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Déconnexion
             </a>
        </div>
    </aside>

    <main class="admin-main">
        @RenderBody()
    </main>

    <style>
        /* ADMIN CURSOR STYLES */
        @@media (pointer: fine) {
            /* Standard cursor for Admin Panel for better usability */
            body { cursor: auto !important; }
            a, button, input, select, textarea, .admin-nav-link { cursor: auto !important; }
        }

        .pro-cursor {
            width: 8px;
            height: 8px;
            background: var(--admin-accent);
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 9999;
            transform: translate(-50%, -50%);
            transition: width 0.3s, height 0.3s, background 0.3s;
        }

        .pro-cursor-follower {
            width: 40px;
            height: 40px;
            border: 1px solid var(--admin-accent);
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 9998;
            transform: translate(-50%, -50%);
            transition: width 0.3s, height 0.3s, border 0.3s, background 0.3s;
        }

        .pro-cursor.hover {
            width: 4px;
            height: 4px;
            background: #fff;
        }

        .pro-cursor-follower.hover {
            width: 60px;
            height: 60px;
            border-color: #fff;
            background: rgba(197, 160, 89, 0.1);
        }
    </style>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const cursor = document.getElementById('proCursor');
            const cursorFollower = document.getElementById('proCursorFollower');

            if (cursor && cursorFollower && window.matchMedia("(pointer: fine)").matches) {
                let mouseX = 0, mouseY = 0;
                let followerX = 0, followerY = 0;

                document.addEventListener('mousemove', (e) => {
                    mouseX = e.clientX;
                    mouseY = e.clientY;
                    cursor.style.left = mouseX + 'px';
                    cursor.style.top = mouseY + 'px';
                });

                const animateCursor = () => {
                    followerX += (mouseX - followerX) * 0.1;
                    followerY += (mouseY - followerY) * 0.1;
                    cursorFollower.style.left = followerX + 'px';
                    cursorFollower.style.top = followerY + 'px';
                    requestAnimationFrame(animateCursor);
                };
                animateCursor();

                const hoverElements = 'a, button, input, select, textarea, .admin-nav-link, .btn-luxury, .action-link, .delete-btn';
                document.querySelectorAll(hoverElements).forEach(el => {
                    el.addEventListener('mouseenter', () => {
                        cursor.classList.add('hover');
                        cursorFollower.classList.add('hover');
                    });
                    el.addEventListener('mouseleave', () => {
                        cursor.classList.remove('hover');
                        cursorFollower.classList.remove('hover');
                    });
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
