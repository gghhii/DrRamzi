@{
    ViewData["Title"] = "Journal - Professeur Ramzi Moatemri";
    Layout = "_Layout";
}

<section class="error-page" style="padding: 200px 50px; text-align: center; background: #000; color: #fff;">
    <div class="error-container reveal-on-scroll">
        <span class="error-badge" style="color: #ffffff; letter-spacing: 0.3em; font-size: 0.8rem; display: block; margin-bottom: 2rem;">PUBLICATIONS</span>
        <h1 class="error-title" style="font-family: var(--font-serif); font-size: 3.5rem; margin-bottom: 2rem;">AUCUN ARTICLE <em>DISPONIBLE</em></h1>
        <p class="error-lead" style="max-width: 600px; margin: 0 auto 3rem; opacity: 0.7; line-height: 1.8;">
            Notre journal scientifique est en cours de mise à jour. Revenez très bientôt pour découvrir nos derniers éditos et cas cliniques.
        </p>
        <a href="/" class="luxury-pill-btn">RETOURNER À L'ACCUEIL</a>
    </div>
</section>
