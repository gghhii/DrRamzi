@model DrAshrafMellouli.Models.Article
@{
    ViewData["Title"] = Model.Title + " - Dr Ramzi Moatemri";
    var relatedArticles = ViewBag.RelatedArticles as IEnumerable<DrAshrafMellouli.Models.Article>;
}

<!-- CINEMATIC ARTICLE HUD -->
<div class="article-hud">
    <div class="hud-top">
        <a href="/Home/Journal" class="hud-back">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>RETOUR AU JOURNAL</span>
        </a>
        <div class="reading-progress-container">
            <div id="readingProgress" class="reading-progress-bar"></div>
        </div>
    </div>
</div>

<article class="lux-article-experience">
    <!-- IMMERSIVE HERO SECTION -->
    <header class="cinematic-hero">
        <div class="hero-parallax-bg" style="background-image: url('@Model.CoverImageUrl');"></div>
        <div class="hero-vignette-ultra"></div>
        <div class="hero-noise"></div>
        
        <div class="hero-content">
            <div class="hero-eyebrow reveal-on-scroll">
                <span class="cat-pill">@Model.CategoryName</span>
                <span class="sep">/</span>
                <span class="date">@Model.DatePublished.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"))</span>
            </div>
            
            <h1 class="hero-title reveal-on-scroll">
                @foreach(var word in Model.Title.Split(' '))
                {
                    <span class="title-word">@word</span>
                }
            </h1>
            
            <div class="hero-meta reveal-on-scroll">
                <div class="author-capsule">
                    <img src="/images/Ramzi-Moatemri.webp" alt="Professeur Ramzi Moatemri" class="author-avatar">
                    <div class="author-details">
                        <span class="author-role">DIRECTEUR SCIENTIFIQUE</span>
                        <span class="author-name">Professeur Ramzi Moatemri</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="hero-scroll-indicator">
            <div class="mouse-icon"></div>
            <span>DÉROULER L'HISTOIRE</span>
        </div>
    </header>

    <!-- CONTENT ARCHITECTURE -->
    <div class="article-architecture">
        <div class="arch-container">
            <!-- SIDEBAR HUD -->
            <aside class="article-aside">
                <div class="aside-sticky">
                    <div class="aside-item">
                        <span class="aside-label">PARTAGE</span>
                        <div class="aside-socials">
                            <a href="#" class="aside-social-link">FB</a>
                            <a href="#" class="aside-social-link">IG</a>
                            <a href="#" class="aside-social-link">WA</a>
                        </div>
                    </div>
                    <div class="aside-item">
                        <span class="aside-label">LECTURE</span>
                        <span class="aside-value" id="readingTime">4 MIN</span>
                    </div>
                </div>
            </aside>

            <!-- MAIN CONTENT FLOW -->
            <main class="article-main reveal-on-scroll">
                <div class="article-lead-paragraph">
                    @Model.Description
                </div>
                
                <div class="article-content-body">
                    @Html.Raw(Model.Content)
                </div>

                <div class="article-footer-meta">
                    <div class="meta-tag-cloud">
                        <span class="tag">#ScienceEsthetique</span>
                        <span class="tag">#DrRamzi</span>
                        <span class="tag">#PrMoatemri</span>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- CURATED SELECTION (RELATED) -->
    @if (relatedArticles != null && relatedArticles.Any())
    {
        <section class="curated-selection">
            <div class="curated-container">
                <header class="curated-header reveal-on-scroll">
                    <p class="curated-eyebrow">LECTURES RECOMMANDÉES</p>
                    <h2 class="curated-title">DÉCOUVRIR D'AUTRES <em>ÉDITOS</em></h2>
                </header>

                <div class="curated-grid">
                    @foreach (var rel in relatedArticles)
                    {
                        <a href="/Home/Article/@rel.Id" class="compact-article-card reveal-on-scroll">
                            <div class="compact-visual">
                                <img src="@rel.CoverImageUrl" alt="@rel.Title">
                            </div>
                            <div class="compact-info">
                                <span class="compact-cat">@rel.CategoryName</span>
                                <h3 class="compact-title">@rel.Title</h3>
                                <span class="compact-read">LIRE <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </section>
    }

    <!-- FINAL JOURNEY CTA -->
    <section class="journey-cta reveal-on-scroll">
        <div class="cta-floating-canvas">
            <h2 class="cta-heading">RÉVÉLEZ VOTRE HARMONIE</h2>
            <p class="cta-text">Un protocole personnalisé commence par une conversation éclairée.</p>
            <a asp-controller="Home" asp-action="Contact" class="cinematic-btn">PRENDRE RENDEZ-VOUS</a>
        </div>
    </section>
</article>

<style>
/* NEW CINEMATIC ARTICLE STYLES */
.lux-article-experience {
    background: #000;
    color: #fff;
    overflow-x: hidden;
}

/* HUD System */
.article-hud {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;
    padding: 2rem 5%;
    pointer-events: none;
}

.hud-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    pointer-events: auto;
}

.hud-back {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: rgba(255,255,255,0.6);
    font-size: 0.65rem;
    letter-spacing: 0.2rem;
    font-weight: 700;
    transition: 0.3s;
}

.hud-back:hover {
    color: var(--color-gold);
}

.reading-progress-container {
    width: 150px;
    height: 2px;
    background: rgba(255,255,255,0.1);
    position: relative;
    overflow: hidden;
}

.reading-progress-bar {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0;
    background: var(--color-gold);
}

/* Cinematic Hero */
.cinematic-hero {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.hero-parallax-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transform: scale(1.1);
    filter: brightness(0.6);
}

.hero-vignette-ultra {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.9) 100%);
}

.hero-noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.03;
    pointer-events: none;
}

.hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    max-width: 1000px;
    padding: 0 5vw;
}

.hero-eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    margin-bottom: 3rem;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--color-gold);
}

.cat-pill {
    text-transform: uppercase;
}

.hero-title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 10vw, 8rem);
    line-height: 0.9;
    text-transform: uppercase;
    margin-bottom: 4rem;
}

.title-word {
    display: inline-block;
    transition: transform 0.8s var(--ease-aesthetic);
}

.hero-meta {
    display: flex;
    justify-content: center;
}

.author-capsule {
    display: flex;
    align-items: center;
    gap: 20px;
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(15px);
    padding: 1rem 2rem;
    border: 1px solid rgba(255,255,255,0.1);
}

.author-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
}

.author-details {
    text-align: left;
}

.author-role {
    display: block;
    font-size: 0.5rem;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    margin-bottom: 2px;
}

.author-name {
    font-size: 0.8rem;
    font-weight: 700;
}

.hero-scroll-indicator {
    position: absolute;
    bottom: 5vh;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    opacity: 0.7;
}

.hero-scroll-indicator span {
    font-size: 0.5rem;
    letter-spacing: 0.3em;
}

/* Architecture */
.article-architecture {
    padding: 10rem 0;
    position: relative;
    background: linear-gradient(to bottom, #000, #050505);
}

.arch-container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 100px;
    padding: 0 5vw;
}

.aside-sticky {
    position: sticky;
    top: 150px;
    display: flex;
    flex-direction: column;
    gap: 4rem;
}

.aside-label {
    display: block;
    font-size: 0.55rem;
    letter-spacing: 0.3em;
    color: rgba(255,255,255,0.3);
    margin-bottom: 1.5rem;
}

.aside-socials {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.aside-social-link {
    text-decoration: none;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    transition: color 0.3s;
}

.aside-social-link:hover {
    color: var(--color-gold);
}

.aside-value {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-gold);
}

/* Main Content */
.article-main {
    max-width: 850px;
}

.article-lead-paragraph {
    font-family: var(--font-serif);
    font-size: 2rem;
    line-height: 1.5;
    color: var(--color-gold);
    margin-bottom: 5rem;
    font-style: italic;
    opacity: 0.9;
}

.article-content-body {
    font-size: 1.15rem;
    line-height: 2;
    color: rgba(255,255,255,0.85);
}

.article-content-body img {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    margin: 3rem 0;
    display: block;
    box-shadow: 0 30px 60px rgba(0,0,0,0.5);
}

.article-content-body p {
    margin-bottom: 2.5rem;
}

.article-content-body h2 {
    font-family: var(--font-serif);
    font-size: 3rem;
    margin: 6rem 0 3rem;
    color: #fff;
}

.article-content-body blockquote {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    font-style: italic;
    color: var(--color-gold);
    border-left: 2px solid var(--color-gold);
    padding-left: 3rem;
    margin: 5rem 0;
    line-height: 1.3;
}

/* Curated Selection */
.curated-selection {
    padding: 10rem 5%;
    border-top: 1px solid rgba(255,255,255,0.05);
}

.curated-container {
    max-width: 1400px;
    margin: 0 auto;
}

.curated-eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.4em;
    color: var(--color-gold);
    margin-bottom: 1.5rem;
}

.curated-title {
    font-family: var(--font-serif);
    font-size: 3rem;
    margin-bottom: 5rem;
}

.curated-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
}

.compact-article-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: 0.5s var(--ease-aesthetic);
}

.compact-visual {
    aspect-ratio: 16/10;
    overflow: hidden;
}

.compact-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s;
}

.compact-article-card:hover .compact-visual img {
    transform: scale(1.1);
}

.compact-cat {
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    display: block;
    margin-bottom: 5px;
}

.compact-title {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    line-height: 1.3;
}

.compact-read {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 8px;
    opacity: 0.5;
    transition: 0.3s;
}

.compact-article-card:hover .compact-read {
    opacity: 1;
    color: var(--color-gold);
    gap: 15px;
}

/* Journey CTA */
.journey-cta {
    padding: 10rem 5%;
    text-align: center;
}

.cta-floating-canvas {
    background: linear-gradient(rgba(255,255,255,0.02), rgba(255,255,255,0.05));
    border: 1px solid rgba(255,255,255,0.1);
    padding: 8rem 2rem;
    max-width: 1000px;
    margin: 0 auto;
}

.cta-heading {
    font-family: var(--font-serif);
    font-size: 4rem;
    margin-bottom: 2rem;
}

.cta-text {
    font-size: 1.1rem;
    opacity: 0.7;
    margin-bottom: 3.5rem;
}

.cinematic-btn {
    display: inline-block;
    padding: 1.5rem 4rem;
    background: var(--color-gold);
    color: #000;
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.3em;
    font-size: 0.7rem;
    transition: 0.4s var(--ease-aesthetic);
}

.cinematic-btn:hover {
    background: #fff;
    transform: scale(1.05);
}

@@media (max-width: 1024px) {
    .arch-container {
        grid-template-columns: 1fr;
        gap: 50px;
    }
    .article-aside {
        display: none;
    }
    .hero-title {
        font-size: 4rem;
    }
    .curated-grid {
        grid-template-columns: 1fr;
    }
}
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Reading progress
        window.addEventListener('scroll', () => {
            const docHeight = document.documentElement.scrollHeight - window.innerHeight;
            const scrolled = (window.scrollY / docHeight) * 100;
            document.getElementById('readingProgress').style.width = scrolled + '%';
        });

        // Parallax effect
        window.addEventListener('scroll', () => {
            const scrolled = window.scrollY;
            const parallaxBg = document.querySelector('.hero-parallax-bg');
            if (parallaxBg) {
                parallaxBg.style.transform = `translateY(${scrolled * 0.3}px) scale(1.1)`;
            }
        });
    });
</script>
