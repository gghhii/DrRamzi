                <span>DESIGN PAR RADIANCE EDITORIAL</span>
            </div>
            <div class="mf-management">DIRECTION MÉDICALE : DR RAMZI MOATEMRI</div>
        </div>
    </div>
</footer>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Filter Logic
        const filterBtns = document.querySelectorAll('.filter-btn');
        const resultItems = document.querySelectorAll('.result-item');

        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                filterBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');

                const filter = btn.dataset.filter;
                resultItems.forEach(item => {
                    if (filter === 'all' || item.dataset.category === filter) {
                        item.style.display = 'grid'; 
                    } else {
                        item.style.display = 'none';
                    }
                });
            });
        });

        // Modal Logic
        const modal = document.getElementById('clinicalModal');
        const closeBtn = document.querySelector('.modal-close-btn');
        const cmCases = document.querySelectorAll('.cm-case');

        const modalImgAnte = document.getElementById('modalImgAnte');
        const modalImgPost = document.getElementById('modalImgPost');
        const modalId = document.getElementById('modalId');
        const modalTitle = document.getElementById('modalTitle');
        const modalDesc = document.getElementById('modalDesc');
        const modalProtocol = document.getElementById('modalProtocol');

        cmCases.forEach(card => {
            card.addEventListener('click', () => {
                const id = card.querySelector('.cm-id').innerText;
                const title = card.querySelector('.cm-case-title').innerText;
                const protocol = card.querySelector('.cm-protocol-tag').innerText;
                const desc = card.querySelector('.cm-case-desc').innerText;
                const anteUrl = card.querySelector('.cm-ante .cm-img').style.backgroundImage.slice(5, -2);
                const postUrl = card.querySelector('.cm-post .cm-img').style.backgroundImage.slice(5, -2);

                modalImgAnte.src = anteUrl;
                modalImgPost.src = postUrl;
                modalId.innerText = id;
                modalTitle.innerText = title;
                modalDesc.innerText = desc;
                modalProtocol.innerText = protocol;

                modal.classList.add('active');
                document.body.style.overflow = 'hidden'; // Prevent scroll
            });
        });

        closeBtn.addEventListener('click', () => {
            modal.classList.remove('active');
            document.body.style.overflow = '';
        });

        modal.addEventListener('click', (e) => {
            if (e.target === modal || e.target.classList.contains('modal-overlay-bg')) {
                modal.classList.remove('active');
                document.body.style.overflow = '';
            }
        });
    });
</script>

<style>
    /* --- HERO REVERSED --- */
    .diorama-hero-reversed {
        height: 100vh;
        background: #000;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        padding-top: 120px;
    }

    .diorama-ambient {
        position: absolute;
