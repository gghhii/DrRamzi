        overflow: visible;
        background: linear-gradient(90deg, transparent, rgba(0,0,0,0.4) 30%, rgba(0,0,0,0.4) 70%, transparent);
    }

    .ecg-svg {
        width: 100%;
        height: 100%;
    }

    .ecg-trace {
        stroke-dasharray: 200 1500;
        stroke-dashoffset: 1700;
        animation: ecgSweep 4.5s linear infinite;
    }

    .ecg-trace-core {
        stroke-dasharray: 200 1500;
        stroke-dashoffset: 1700;
        animation: ecgSweep 4.5s linear infinite;
        filter: drop-shadow(0 0 10px #fff) drop-shadow(0 0 20px var(--color-gold));
