        object-fit: cover;
        filter: grayscale(1) contrast(1.1);
        transition: transform 2s var(--ease-aesthetic);
    }

    .stage-visual-wrap-right:hover .stage-img {
        transform: scale(1.05);
    }

    .stage-scan-line {
        position: absolute;
        top: 0;
        left: -100%;
