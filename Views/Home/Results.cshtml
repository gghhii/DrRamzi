@model IEnumerable<DrAshrafMellouli.Models.Result>
@{
    ViewData["Title"] = "Avant & Après - Dr Ramzi Moatemri";
}

<!-- REFINED DIORAMA HERO: RESULTS (TEXT LEFT / IMAGE RIGHT) -->
<section id="hero" class="diorama-hero-reversed">
    <!-- Background Ambient Elements -->
    <div class="diorama-ambient">
        <div class="ambient-orb orb-1"></div>
        <div class="ambient-orb orb-2"></div>
        <div class="ambient-grid"></div>
    </div>

    <div class="diorama-container">
        <!-- Large Background Signature -->
        <div class="diorama-signature">ARCHIVE</div>

        <div class="diorama-stage-reversed">
            <!-- Left Side: Narrative Content -->
            <div class="stage-content-left reveal-on-scroll">
                <div class="content-clean-block">
                    <header class="content-header">
                        <span class="h-line"></span>
                        <span class="h-tag">ARCHIVES DE PERFECTION CLINIQUE</span>
                    </header>
                    
                    <h1 class="diorama-title">
                        L'ART DU <br>
                        <span class="italic-accent">RÉSULTAT</span>
                    </h1>

                    <div class="diorama-description">
                        <p>Une archive transparente de transformations. Où la précision mathématique rencontre l'harmonie visible, documentée avec une rigueur scientifique absolue.</p>
                    </div>

                    <div class="diorama-actions">
                        <a href="#gallery" class="btn-diorama">
                            <span class="btn-text">EXPLORER LE REGISTRE</span>
                            <span class="btn-arrow">→</span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Right Side: Image Layer -->
            <div class="stage-visual-wrap-right reveal-on-scroll">
                <img src="/images/i5.png" alt="Clinical Results Architecture" class="stage-img">
                <div class="stage-scan-line"></div>
                <div class="stage-frame-corners"></div>

                <!-- CLINICAL ECG SIGNAL ANIMATION -->
                <div class="clinical-ecg-overlay">
                    <svg viewBox="0 0 800 100" preserveAspectRatio="none" class="ecg-svg">
                        <polyline points="0,50 350,50 365,20 380,80 395,20 410,50 800,50" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="2" />
                        <polyline points="0,50 350,50 365,20 380,80 395,20 410,50 800,50" fill="none" stroke="var(--color-gold)" stroke-width="8" opacity="0.6" style="filter: blur(4px);" class="ecg-trace" />
                        <polyline points="0,50 350,50 365,20 380,80 395,20 410,50 800,50" fill="none" stroke="#ffffff" stroke-width="3" class="ecg-trace-core" />
                    </svg>
                </div>

                <!-- HUD Data Points on Image -->
                <div class="floating-data d-top" style="top: 15%; right: 10%;">
                    <div class="d-dot"></div>
                    <div class="d-info">
                        <span class="d-label">PREUVE</span>
                        <span class="d-val">1,240+ CAS</span>
                    </div>
                </div>
                <div class="floating-data d-bottom" style="bottom: 15%; left: 10%;">
                    <div class="d-dot"></div>
                    <div class="d-info">
                        <span class="d-label">HARMONIE</span>
                        <span class="d-val">v5.0.0</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- RESULTS MONOLITH SECTION: LANDSCAPE GLASS EDITION -->
<section id="gallery" class="clinical-monolith section-paper" style="background: #fff; color: #000; padding-top: 10rem;">
    <div class="cm-technical-bg" style="opacity: 0.1;"></div>
    
    <div class="cm-archive-container">
        <!-- Filter Controls -->
        <div class="lab-filter-bar reveal-on-scroll" style="margin-bottom: 12rem;">
            <button class="filter-btn active" data-filter="all">TOUS LES CAS</button>
            <button class="filter-btn" data-filter="visage">VISAGE</button>
            <button class="filter-btn" data-filter="corps">CORPS</button>
            <button class="filter-btn" data-filter="laser">LASER</button>
            <button class="filter-btn" data-filter="cheveux">CHEVEUX</button>
        </div>

        <div class="cm-wrapper" id="resultsGrid">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="cm-case reveal-on-scroll result-item" data-category="@item.Category.ToString().ToLower()">
                        <div class="cm-split cm-ante">
                            <div class="cm-img-letterbox">
                                <div class="cm-img" style="background-image: url('@item.BeforeImageUrl')"></div>
                                <div class="cm-overlay"></div>
                            </div>
                            <span class="cm-status-tag">STATUS // ANTE</span>
                        </div>

                        <div class="cm-glass-center-landscape">
                            <div class="cm-glass-inner">
                                <div class="cm-dot-indicator"></div>
                                <span class="cm-id">@item.CaseNumber</span>
                                <h3 class="cm-case-title">@item.Title</h3>
                                <div class="cm-protocol-tag">@item.ProtocolName</div>
                                <div class="cm-separator"></div>
                                <p class="cm-case-desc">@item.Description</p>
                                <a href="javascript:void(0)" class="cm-action">EXPLORER L'ANALYSE ↗</a>
                            </div>
                            <div class="cm-scanner-beam"></div>
                        </div>

                        <div class="cm-split cm-post">
                            <div class="cm-img-letterbox">
                                <div class="cm-img" style="background-image: url('@item.AfterImageUrl')"></div>
                                <div class="cm-overlay"></div>
                            </div>
                            <span class="cm-status-tag">STATUS // POST</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <!-- Fallback Slide: Exact parity with User Screenshot -->
                <div class="cm-case reveal-on-scroll result-item" data-category="visage">
                    <div class="cm-split cm-ante">
                        <div class="cm-img-letterbox">
                            <div class="cm-img" style="background-image: url('/images/injections_before.png')"></div>
                            <div class="cm-overlay"></div>
                        </div>
                        <span class="cm-status-tag">STATUS // ANTE</span>
                    </div>

                    <div class="cm-glass-center-landscape">
                        <div class="cm-glass-inner">
                            <div class="cm-dot-indicator"></div>
                            <span class="cm-id">CASE_0821</span>
                            <h3 class="cm-case-title">TEST</h3>
                            <div class="cm-protocol-tag">TEST</div>
                            <div class="cm-separator"></div>
                            <p class="cm-case-desc">test</p>
                            <a href="javascript:void(0)" class="cm-action">EXPLORER L'ANALYSE ↗</a>
                        </div>
                        <div class="cm-scanner-beam"></div>
                    </div>

                    <div class="cm-split cm-post">
                        <div class="cm-img-letterbox">
                            <div class="cm-img" style="background-image: url('/images/injections_after.png')"></div>
                            <div class="cm-overlay"></div>
                        </div>
                        <span class="cm-status-tag">STATUS // POST</span>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- CLINICAL EXPANSION MODAL (FULLSCREEN) -->
<div id="clinicalModal" class="clinical-modal">
    <button class="modal-close-btn">&times;</button>
    <div class="modal-overlay-bg"></div>
    <div class="modal-content-wrap">
        <div class="modal-images-split">
            <div class="modal-image-panel ante">
                <img id="modalImgAnte" src="" alt="Ante">
                <span class="modal-status-label">ANTE // PRÉ-OPÉRATOIRE</span>
            </div>
            <div class="modal-image-panel post">
                <img id="modalImgPost" src="" alt="Post">
                <span class="modal-status-label">POST // RÉSULTAT FINAL</span>
            </div>
        </div>
        <div class="modal-details-bar">
            <div class="modal-id-block">
                <span id="modalId">ID // 0000</span>
                <h2 id="modalTitle">TITRE DU CAS</h2>
            </div>
            <div class="modal-desc-block">
                <p id="modalDesc">Description détaillée du protocole clinique...</p>
            </div>
            <div class="modal-protocol-block">
                <span class="p-label">PROTOCOLE</span>
                <span id="modalProtocol" class="p-val">PROTOCOLE TEST</span>
            </div>
        </div>
    </div>
</div>

<section class="artistic-cta reveal-on-scroll">
    <div class="cta-video-wrap">
        <video autoplay muted loop playsinline class="cta-bg-video">
            <source src="/videos/v2.mp4" type="video/mp4">
