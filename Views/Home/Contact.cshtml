@{
    ViewData["Title"] = "Contact - Dr Ramzi Moatemri";
}


<section id="hero" class="diorama-hero-reversed">
    <div class="diorama-ambient">
        <div class="ambient-orb orb-1"></div>
        <div class="ambient-orb orb-2"></div>
        <div class="ambient-grid"></div>
    </div>

    <div class="diorama-container">
        <!-- Large Background Signature -->
        <div class="diorama-signature">CONTACT</div>

        <div class="diorama-stage-reversed">
            <!-- Left Side: Narrative Content -->
            <div class="stage-content-left reveal-on-scroll">
                <div class="content-clean-block">
                    <header class="content-header">
                        <span class="h-line"></span>
                        <span class="h-tag">SYSTEM: CONTACT</span>
                    </header>
                    
                    <h1 class="diorama-title">
                        INTERACTION <br>
                        <span class="italic-accent">CLINIQUE</span>
                    </h1>

                    <div class="diorama-description">
                        <p>Initiez votre transformation. Notre équipe est prête à vous guider à travers nos protocoles esthétiques d'excellence à l'Immeuble Misk Elil.</p>
                    </div>

                    <div class="diorama-actions">
                        <a href="#form" class="btn-diorama">
                            <span class="btn-text">PRENDRE CONTACT</span>
                            <span class="btn-arrow">→</span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Right Side: Image Layer -->
            <div class="stage-visual-wrap-right reveal-on-scroll">
                <img src="/images/i5.png" alt="Contact Architecture" class="stage-img">
                <div class="stage-scan-line"></div>
                <div class="stage-frame-corners"></div>

                <!-- CLINICAL ECG SIGNAL ANIMATION -->
                <div class="clinical-ecg-overlay">
                    <svg viewBox="0 0 800 100" preserveAspectRatio="none" class="ecg-svg">
                        <polyline points="0,50 350,50 365,20 380,80 395,20 410,50 800,50" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="2" />
                        <polyline points="0,50 350,50 365,20 380,80 395,20 410,50 800,50" fill="none" stroke="var(--color-gold)" stroke-width="8" opacity="0.6" style="filter: blur(4px);" class="ecg-trace" />
                        <polyline points="0,50 350,50 365,20 380,80 395,20 410,50 800,50" fill="none" stroke="#ffffff" stroke-width="3" class="ecg-trace-core" />
                    </svg>
                </div>

                <!-- HUD Data Points on Image -->
                <div class="floating-data d-top" style="top: 15%; right: 10%;">
                    <div class="d-dot"></div>
                    <div class="d-info">
                        <span class="d-label">LAT</span>
                        <span class="d-val">35.8450</span>
                    </div>
                </div>
                <div class="floating-data d-bottom" style="bottom: 15%; left: 10%;">
                    <div class="d-dot"></div>
                    <div class="d-info">
                        <span class="d-label">LNG</span>
                        <span class="d-val">10.6116</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- MAIN CONTACT BODY -->
</section>

<!-- MAIN CONTACT BODY -->
<section id="form" class="contact-body section-padding section-paper">
    <div class="contact-body-container">
        <div class="contact-body-grid">

            <!-- LEFT: FORM -->
            <div class="contact-form-panel reveal-on-scroll">
                <div class="panel-heading">
                    <span class="panel-label">FORMULAIRE</span>
                    <h2 class="panel-title">Réserver une Consultation</h2>
                    <p class="panel-desc">Remplissez ce formulaire et notre équipe vous contactera sous 24h pour confirmer votre rendez-vous.</p>
                </div>

                <form class="contact-form" id="contactForm">
                    <div class="form-row-2">
                        <div class="cf-group">
                            <label class="cf-label" for="fullName">Nom Complet</label>
                            <input class="cf-input" type="text" id="fullName" placeholder="Dr. / M. / Mme..." required />
                        </div>
                        <div class="cf-group">
                            <label class="cf-label" for="phone">Téléphone</label>
                            <input class="cf-input" type="tel" id="phone" placeholder="+216 xx xxx xxx" />
                        </div>
                    </div>

                    <div class="cf-group">
                        <label class="cf-label" for="email">Adresse Email</label>
                        <input class="cf-input" type="email" id="email" placeholder="vous@email.com" required />
                    </div>

                    <div class="cf-group">
                        <label class="cf-label" for="service">Soin d'Intérêt</label>
                        <select class="cf-input" id="service">
                            <option value="">Choisir un protocole...</option>
                            <option>Injections & Sculpture Faciale</option>
                            <option>Laser Fractionné & Resurfacing</option>
                            <option>Épilation Laser</option>
                            <option>Traitement de la Chute de Cheveux</option>
                            <option>Peeling Chimique</option>
                            <option>Hydrafacial MD</option>
                            <option>Dermatologie Générale</option>
                            <option>Autre</option>
                        </select>
                    </div>

                    <div class="cf-group">
                        <label class="cf-label" for="message">Votre Message</label>
                        <textarea class="cf-input cf-textarea" id="message" rows="5" placeholder="Décrivez brièvement vos objectifs esthétiques..."></textarea>
                    </div>

                    <button type="submit" class="cf-submit-btn">
                        <span>ENVOYER MA DEMANDE</span>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </button>
                </form>
            </div>

            <!-- RIGHT: INFO -->
            <div id="info" class="contact-info-panel reveal-on-scroll" style="transition-delay:0.2s;">

                <!-- Clinic Card -->
                <div class="info-card">
                    <div class="info-card-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    </div>
                    <div class="info-card-body">
                        <span class="info-card-label">ADRESSE</span>
                        <h3 class="info-card-title">Dr Ramzi Moatemri</h3>
                        <p class="info-card-text">Immeuble Misk Elil<br>4ème Étage, Bureau N°42<br>Khézama Est, Sousse, Tunisie</p>
                        <a href="https://maps.app.goo.gl/YourNewMapLink" target="_blank" class="info-card-link">
                            Ouvrir dans Google Maps →
                        </a>
                    </div>
                </div>

                <!-- Phone Card -->
                <div class="info-card">
                    <div class="info-card-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.81 19.79 19.79 0 01.13 2.18 2 2 0 012.11 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.09a16 16 0 006 6l.46-.46a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                    </div>
                    <div class="info-card-body">
                        <span class="info-card-label">TÉLÉPHONE</span>
                        <h3 class="info-card-title">+216 98 643 807</h3>
                        <p class="info-card-text">Disponible Lun–Ven, 09:00–18:00<br>Sam: 09:00–13:00</p>
                    </div>
                </div>

                <!-- Email Card -->
                <div class="info-card">
                    <div class="info-card-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    </div>
                    <div class="info-card-body">
                        <span class="info-card-label">EMAIL</span>
                        <h3 class="info-card-title">moatemri_ramzi@yahoo.fr</h3>
                        <p class="info-card-text">Réponse garantie sous 24h ouvrables</p>
                    </div>
                </div>

                <!-- Hours -->
                <div class="info-hours">
                    <span class="info-card-label">HORAIRES D'OUVERTURE</span>
                    <div class="hours-grid">
                        <div class="hours-row">
                            <span>Lundi – Vendredi</span>
                            <span class="hours-time">09:00 – 18:00</span>
                        </div>
                        <div class="hours-row">
                            <span>Samedi</span>
                            <span class="hours-time">09:00 – 13:00</span>
                        </div>
                        <div class="hours-row hours-closed">
                            <span>Dimanche</span>
                            <span class="hours-time">Fermé</span>
                        </div>
                    </div>
                </div>

                <!-- Social -->
                <div class="info-social">
                    <a href="#" class="social-pill">Instagram</a>
                    <a href="#" class="social-pill">Facebook</a>
                    <a href="#" class="social-pill">LinkedIn</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FULL-WIDTH MAP -->
</section>

<!-- FULL-WIDTH MAP -->
<section id="map" class="contact-map-section section-paper">
    <div class="map-header reveal-on-scroll">
        <span class="map-label">LOCALISATION</span>
        <h2 class="map-title">Nous Trouver</h2>
    </div>
    <div class="map-wrapper">
        <iframe
            src="https://maps.google.com/maps?q=Cabinet+Professeur+Ramzi+Moatemri+Immeuble+Misk+Elil+Sousse&t=&z=16&ie=UTF8&iwloc=&output=embed"
