<style>
    /* Reuse exact Face page diorama hero styles */
    .diorama-hero-reversed {
        height: 100vh; background: #000; position: relative;
        overflow: hidden; display: flex; align-items: center;
        justify-content: center; padding-top: 120px;
    }
    .diorama-ambient { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
    .ambient-orb { position: absolute; width: 600px; height: 600px; background: radial-gradient(circle, rgba(255,255,255,0.03) 0%, transparent 70%); border-radius: 50%; filter: blur(80px); }
    .orb-1 { top: -10%; left: -10%; }
    .orb-2 { bottom: -10%; right: -10%; background: radial-gradient(circle, rgba(255,255,255,0.02) 0%, transparent 70%); }
    .ambient-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 100px 100px; mask-image: radial-gradient(circle at center, black, transparent 80%); }
    .diorama-container { width: 100%; max-width: 1600px; padding: 0 5%; position: relative; z-index: 10; }
    .diorama-signature { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-family: var(--font-serif); font-size: 18vw; color: rgba(255,255,255,0.02); white-space: nowrap; pointer-events: none; letter-spacing: -0.05em; z-index: 0; }
    .diorama-stage-reversed { display: flex; flex-direction: row; align-items: center; position: relative; height: 600px; gap: 10%; }
    .stage-content-left { position: relative; z-index: 20; width: 30%; }
    .content-header { display: flex; align-items: center; gap: 15px; margin-bottom: 2.5rem; }
    .h-line { width: 30px; height: 1px; background: var(--color-gold); }
    .h-tag { font-size: 0.55rem; letter-spacing: 0.4em; color: rgba(255,255,255,0.5); font-weight: 700; }
    .diorama-title { font-family: var(--font-serif); font-size: clamp(2.5rem, 4vw, 4.5rem); line-height: 0.9; margin-bottom: 2.5rem; color: #fff; text-transform: uppercase; }
    .diorama-title .italic-accent { font-style: italic; color: #fff; font-weight: 300; opacity: 0.9; }
    .diorama-description { margin-bottom: 3.5rem; max-width: 500px; }
    .diorama-description p { font-size: 1.1rem; line-height: 1.8; color: rgba(255,255,255,0.6); font-weight: 300; }
    .stage-visual-wrap-right { position: relative; width: 60%; height: 100%; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); }
    .stage-img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1) contrast(1.1); transition: transform 2s ease; }
    .stage-visual-wrap-right:hover .stage-img { transform: scale(1.05); }
    .stage-scan-line { position: absolute; top: 0; left: -100%; width: 50%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent); animation: scanH 8s infinite linear; }
    @@keyframes scanH { 0% { left: -50%; } 100% { left: 100%; } }
    .stage-frame-corners::before, .stage-frame-corners::after { content: ''; position: absolute; width: 40px; height: 40px; border: 1px solid var(--color-gold); z-index: 5; }
    .stage-frame-corners::before { top: 20px; left: 20px; border-right: 0; border-bottom: 0; }
    .stage-frame-corners::after { bottom: 20px; right: 20px; border-left: 0; border-top: 0; }
    .btn-diorama { display: inline-flex; align-items: center; gap: 20px; padding: 1.2rem 2.5rem; background: #fff; color: #000; text-decoration: none; font-size: 0.7rem; font-weight: 800; letter-spacing: 0.2em; transition: all 0.4s ease; }
    .btn-diorama:hover { background: var(--color-gold); transform: translateY(-5px); }
    .floating-data { position: absolute; display: flex; align-items: center; gap: 15px; z-index: 30; }
    .d-dot { width: 8px; height: 8px; background: #fff; border-radius: 50%; box-shadow: 0 0 15px #fff; animation: pulseD 2s infinite; }
    @@keyframes pulseD { 0%,100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.5); opacity: 0.5; } }
    .d-info { display: flex; flex-direction: column; background: rgba(0,0,0,0.8); backdrop-filter: blur(10px); padding: 10px 15px; border: 1px solid rgba(255,255,255,0.1); }
    .d-label { font-size: 0.45rem; color: #fff; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.6; }
    .d-val { font-size: 0.6rem; color: #fff; font-weight: 800; }

    /* Clinical ECG Overlay */
    .clinical-ecg-overlay { position: absolute; bottom: 30%; left: 0; width: 100%; height: 80px; z-index: 25; pointer-events: none; overflow: visible; background: linear-gradient(90deg, transparent, rgba(0,0,0,0.4) 30%, rgba(0,0,0,0.4) 70%, transparent); }
    .ecg-svg { width: 100%; height: 100%; }
    .ecg-trace, .ecg-trace-core { stroke-dasharray: 200 1500; stroke-dashoffset: 1700; animation: ecgSweep 4.5s linear infinite; }
    .ecg-trace-core { filter: drop-shadow(0 0 10px #fff) drop-shadow(0 0 20px var(--color-gold)); }
    @@keyframes ecgSweep { to { stroke-dashoffset: 0; } }

    /* White Editorial Cards */
    .white-cards-section { padding: 15rem 0; background: #0a0a0a !important; }
    .bg-white { background-color: #0a0a0a !important; }
    .cards-container { max-width: 1400px; margin: 0 auto; padding: 0 5%; }
    .white-matrix-header { margin-bottom: 8rem; text-align: center; display: flex; flex-direction: column; align-items: center; }
    .wm-title { font-family: var(--font-serif); font-size: clamp(3.5rem, 6vw, 6rem); line-height: 0.85; color: #fff; text-transform: uppercase; letter-spacing: -0.02em; }
    .wm-title .italic-serif { font-style: italic; font-weight: 300; display: block; margin-top: 0.5rem; color: #fff; opacity: 0.85; }
    .wm-line { width: 80px; height: 2px; background: #fff; margin-top: 2.5rem; }
    .wm-subtitle { max-width: 640px; margin: 2.5rem auto 0; font-size: 1rem; line-height: 1.75; color: rgba(255,255,255,0.5); font-weight: 300; text-align: center; }
    .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 4rem 3rem; }
    .editorial-card { background: #fdfdfd; border: 1px solid rgba(0,0,0,0.05); transition: transform 0.5s ease, box-shadow 0.5s ease; display: flex; flex-direction: column; }
    .editorial-card:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.05); }
    .card-visual { position: relative; aspect-ratio: 4/5; overflow: hidden; }
    .card-visual img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1) contrast(1.1); transition: transform 1.5s ease, filter 1.5s ease; }
    .editorial-card:hover .card-visual img { transform: scale(1.05); filter: grayscale(0) contrast(1); }
    .card-num { position: absolute; top: 20px; left: 20px; background: #fff; color: #000; font-size: 0.6rem; font-weight: 800; padding: 8px 12px; letter-spacing: 0.2em; z-index: 2; border: 1px solid rgba(0,0,0,0.1); }
    .card-content { padding: 3rem 2.5rem; display: flex; flex-direction: column; flex: 1; }
    .card-name { font-family: var(--font-serif); font-size: 1.8rem; color: #000; text-transform: uppercase; margin-bottom: 1.5rem; line-height: 1.2; }
    .card-desc { font-size: 1rem; line-height: 1.7; color: rgba(0,0,0,0.6); font-weight: 300; margin-bottom: 2.5rem; flex: 1; }
    .card-link { font-size: 0.65rem; color: #000; letter-spacing: 0.2em; font-weight: 800; text-decoration: none; position: relative; display: inline-flex; align-items: center; align-self: flex-start; transition: all 0.4s ease; }
    .card-link::after { content: ''; position: absolute; bottom: -5px; left: 0; width: 0; height: 1px; background: #000; transition: width 0.4s ease; }
    .editorial-card:hover .card-link::after { width: 100%; }
    .editorial-card:hover .card-link { transform: translateX(5px); }

    /* CTA */
    .artistic-cta { position: relative; overflow: hidden; padding: 10rem 5%; background: #000; }
    .cta-video-wrap { position: absolute; inset: 0; z-index: 1; }
    .cta-video-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.5), rgba(0,0,0,0.3), rgba(0,0,0,0.5)); }
    .cta-inner { position: relative; z-index: 10; text-align: center; max-width: 800px; margin: 0 auto; }

    @@media (max-width: 1024px) {
