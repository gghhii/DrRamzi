@{
    ViewData["Title"] = "Chirurgie Esthétique | Pr. Ramzi Moatemri";
}

<!-- DIORAMA HERO: CHIRURGIE -->
<section id="hero" class="diorama-hero-reversed">
    <div class="diorama-ambient">
        <div class="ambient-orb orb-1"></div>
        <div class="ambient-orb orb-2"></div>
        <div class="ambient-grid"></div>
    </div>

    <div class="diorama-container">
        <div class="diorama-signature">CHIRURGIE</div>
        <div class="diorama-stage-reversed">
            <!-- Left: Text -->
            <div class="stage-content-left reveal-on-scroll">
                <div class="content-clean-block">
                    <header class="content-header">
                        <span class="h-line"></span>
                        <span class="h-tag">CHIRURGIE ESTHÉTIQUE & MAXILLO-FACIALE</span>
                    </header>
                    <h1 class="diorama-title">
                        L'ART DE LA <br>
                        <span class="italic-accent">Métamorphose</span>
                    </h1>
                    <div class="diorama-description">
                        <p>Sous l'expertise du Professeur Ramzi Moatemri, la chirurgie esthétique devient un acte de création architecturale. Chaque intervention est conçue pour révéler votre harmonie naturelle avec une précision académique de haut niveau.</p>
                    </div>
                    <div class="diorama-actions">
                        <a href="#interventions" class="btn-diorama">
                            <span class="btn-text">DÉCOUVRIR LES INTERVENTIONS</span>
                            <span class="btn-arrow">→</span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Right: Image -->
            <div class="stage-visual-wrap-right reveal-on-scroll">
                <img src="~/images/cher.png" alt="Chirurgie esthétique Pr. Ramzi Moatemri" class="stage-img">
                <div class="stage-scan-line"></div>
                
                <!-- CLINICAL ECG SIGNAL ANIMATION -->
                <div class="clinical-ecg-overlay">
                    <svg viewBox="0 0 800 100" preserveAspectRatio="none" class="ecg-svg">
                        <polyline points="0,50 350,50 365,20 380,80 395,20 410,50 800,50" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="2" />
                        <polyline points="0,50 350,50 365,20 380,80 395,20 410,50 800,50" fill="none" stroke="var(--color-gold)" stroke-width="8" opacity="0.6" style="filter: blur(4px);" class="ecg-trace" />
                        <polyline points="0,50 350,50 365,20 380,80 395,20 410,50 800,50" fill="none" stroke="#ffffff" stroke-width="3" class="ecg-trace-core" />
                    </svg>
                </div>

                <div class="stage-frame-corners"></div>
                <div class="floating-data d-top" style="top: 15%; right: 10%;">
                    <div class="d-dot"></div>
                    <div class="d-info">
                        <span class="d-label">EXPERTISE</span>
                        <span class="d-val">20+ ANS</span>
                    </div>
                </div>
                <div class="floating-data d-bottom" style="bottom: 15%; left: 10%;">
                    <div class="d-dot"></div>
                    <div class="d-info">
                        <span class="d-label">ACADÉMIQUE</span>
                        <span class="d-val">PROF. AGRÉGÉ</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<!-- SURGICAL INTERVENTIONS CARDS -->
<section id="interventions" class="white-cards-section bg-white">
    <div class="cards-container">
        <header class="white-matrix-header reveal-on-scroll">
            <h2 class="wm-title">
                INTERVENTIONS DE <br>
                <span class="italic-serif">Chirurgie Esthétique</span>
            </h2>
            <div class="wm-line"></div>
            <p class="wm-subtitle">Sous la direction du Professeur Ramzi Moatemri, chaque intervention chirurgicale est pensée comme un acte de précision architecturale — alliant sécurité académique, résultats naturels et accompagnement personnalisé.</p>
        </header>

        <div class="cards-grid">
            <!-- Card 01 -->
            <div class="editorial-card reveal-on-scroll">
                <div class="card-visual">
                    <img src="~/images/surgery_precision.png" alt="Rhinoplastie">
                    <span class="card-num">01</span>
                </div>
                <div class="card-content">
                    <h3 class="card-name">RHINOPLASTIE</h3>
                    <p class="card-desc">Remodelage du nez pour une harmonie faciale optimale. Une procédure de haute précision qui respecte les proportions naturelles du visage et l'identité du patient.</p>
                    <a asp-controller="Home" asp-action="Contact" class="card-link">PRENDRE RENDEZ-VOUS →</a>
                </div>
            </div>

            <!-- Card 02 -->
            <div class="editorial-card reveal-on-scroll" style="transition-delay: 0.1s;">
                <div class="card-visual">
                    <img src="~/images/face.png" alt="Lifting du visage">
                    <span class="card-num">02</span>
                </div>
                <div class="card-content">
                    <h3 class="card-name">LIFTING DU VISAGE</h3>
                    <p class="card-desc">Restauration architecturale des volumes et des contours faciaux. Un lifting naturel qui redonne une apparence reposée et rajeunie, sans artifice apparent.</p>
                    <a asp-controller="Home" asp-action="Contact" class="card-link">PRENDRE RENDEZ-VOUS →</a>
                </div>
            </div>

            <!-- Card 03 -->
            <div class="editorial-card reveal-on-scroll" style="transition-delay: 0.2s;">
                <div class="card-visual">
                    <img src="~/images/i3.png" alt="Blépharoplastie">
                    <span class="card-num">03</span>
                </div>
                <div class="card-content">
                    <h3 class="card-name">BLÉPHAROPLASTIE</h3>
                    <p class="card-desc">Chirurgie de rajeunissement des paupières supérieures et/ou inférieures pour un regard ouvert, lumineux et naturellement expressif.</p>
                    <a asp-controller="Home" asp-action="Contact" class="card-link">PRENDRE RENDEZ-VOUS →</a>
                </div>
            </div>

            <!-- Card 04 -->
            <div class="editorial-card reveal-on-scroll" style="transition-delay: 0.3s;">
                <div class="card-visual">
                    <img src="~/images/body.png" alt="Liposuccion">
                    <span class="card-num">04</span>
                </div>
                <div class="card-content">
                    <h3 class="card-name">LIPOSUCCION HAUTE DÉFINITION</h3>
                    <p class="card-desc">Sculpture corporelle de précision pour éliminer les amas graisseux résistants et révéler les contours naturels de la silhouette avec une haute définition.</p>
                    <a asp-controller="Home" asp-action="Contact" class="card-link">PRENDRE RENDEZ-VOUS →</a>
                </div>
            </div>

            <!-- Card 05 -->
            <div class="editorial-card reveal-on-scroll" style="transition-delay: 0.4s;">
                <div class="card-visual">
                    <img src="~/images/i5.png" alt="Augmentation mammaire">
                    <span class="card-num">05</span>
                </div>
                <div class="card-content">
                    <h3 class="card-name">AUGMENTATION MAMMAIRE</h3>
                    <p class="card-desc">Harmonisation et équilibre de la silhouette par implants ou lipofilling. Une chirurgie personnalisée pour un résultat naturel et proportionné au morphotype.</p>
                    <a asp-controller="Home" asp-action="Contact" class="card-link">PRENDRE RENDEZ-VOUS →</a>
                </div>
            </div>

            <!-- Card 06 -->
            <div class="editorial-card reveal-on-scroll" style="transition-delay: 0.5s;">
                <div class="card-visual">
                    <img src="~/images/i4.png" alt="Abdominoplastie">
                    <span class="card-num">06</span>
                </div>
                <div class="card-content">
                    <h3 class="card-name">ABDOMINOPLASTIE</h3>
                    <p class="card-desc">Reconstruction et raffermissement de la paroi abdominale. Indiquée après une grossesse ou une perte de poids importante, elle redessine le ventre avec précision.</p>
                    <a asp-controller="Home" asp-action="Contact" class="card-link">PRENDRE RENDEZ-VOUS →</a>
                </div>
            </div>
        </div>
    </div>
</section>


<!-- TECH METRICS: EXPERTISE CHIRURGICALE -->
<section id="expertise" class="tech-metrics-section">
    <div class="gallery-container">
        <header class="gallery-header reveal-on-scroll">
            <h2 class="gallery-title">PHILOSOPHIE <br> <em>& STANDARDS</em></h2>
            <div class="gallery-line"></div>
        </header>
        <div class="metrics-grid">
            <div class="metric-card reveal-on-scroll">
                <span class="metric-num">STANDARD 01</span>
                <h3 class="metric-title">SÉCURITÉ ACADÉMIQUE</h3>
                <p class="metric-desc">En tant que Professeur Agrégé en Chirurgie Maxillo-Faciale, le Pr. Moatemri applique des protocoles cliniques conformes aux standards universitaires internationaux les plus exigeants.</p>
            </div>
            <div class="metric-card reveal-on-scroll" style="transition-delay: 0.1s;">
                <span class="metric-num">STANDARD 02</span>
                <h3 class="metric-title">RÉSULTATS NATURELS</h3>
                <p class="metric-desc">Chaque intervention est planifiée selon une lecture architecturale de l'anatomie du patient, garantissant des résultats subtils, durables et en parfaite harmonie avec les traits naturels.</p>
            </div>
            <div class="metric-card reveal-on-scroll" style="transition-delay: 0.2s;">
                <span class="metric-num">STANDARD 03</span>
                <h3 class="metric-title">SUIVI PERSONNALISÉ</h3>
                <p class="metric-desc">Un accompagnement rigoureux de la consultation pré-opératoire jusqu'à la récupération complète, pour une expérience patient sereine et des résultats optimisés à long terme.</p>
            </div>
        </div>
    </div>
</section>


<!-- JOURNEY: LE PROTOCOLE CHIRURGICAL -->
<section id="journey" class="procedure-journey">
    <div class="journey-container">
        <header class="gallery-header reveal-on-scroll">
            <h2 class="gallery-title">VOTRE PARCOURS <br> <em>CHIRURGICAL</em></h2>
            <div class="gallery-line"></div>
        </header>
        <div class="journey-steps">
            <div class="journey-step reveal-on-scroll">
                <div class="step-line"></div>
                <div class="step-dot"></div>
                <span class="step-label">PHASE 01</span>
                <h3 class="step-title">CONSULTATION</h3>
                <p class="step-text">Évaluation approfondie de votre anatomie, discussion de vos attentes et élaboration d'un plan chirurgical personnalisé en toute confidentialité.</p>
            </div>
            <div class="journey-step reveal-on-scroll" style="transition-delay: 0.1s;">
                <div class="step-line"></div>
                <div class="step-dot"></div>
                <span class="step-label">PHASE 02</span>
                <h3 class="step-title">PRÉPARATION</h3>
                <p class="step-text">Bilan pré-opératoire complet, instructions personnalisées et préparation médicale pour garantir les meilleures conditions chirurgicales.</p>
            </div>
            <div class="journey-step reveal-on-scroll" style="transition-delay: 0.2s;">
                <div class="step-line"></div>
                <div class="step-dot"></div>
                <span class="step-label">PHASE 03</span>
                <h3 class="step-title">INTERVENTION</h3>
                <p class="step-text">L'opération est réalisée dans des cliniques partenaires de prestige, avec une équipe médicale dédiée et une technologie chirurgicale de pointe.</p>
            </div>
            <div class="journey-step reveal-on-scroll" style="transition-delay: 0.3s;">
                <div class="step-line"></div>
                <div class="step-dot"></div>
                <span class="step-label">PHASE 04</span>
                <h3 class="step-title">RÉCUPÉRATION</h3>
                <p class="step-text">Suivi post-opératoire rigoureux et personnalisé pour une récupération sereine, une cicatrisation optimale et des résultats finaux remarquables.</p>
            </div>
        </div>
    </div>
</section>


<!-- CTA FINAL -->
<section class="artistic-cta reveal-on-scroll">
    <div class="cta-video-wrap">
        <video autoplay muted loop playsinline class="cta-bg-video">
            <source src="/videos/v2.mp4" type="video/mp4">
        </video>
        <div class="cta-video-overlay"></div>
    </div>
    <div class="cta-inner">
        <span class="cta-eyebrow">CHIRURGIE ESTHÉTIQUE</span>
        <div class="cta-ornament"></div>
        <h2 class="cta-title">PRÊT À RÉVÉLER <br> VOTRE POTENTIEL ?</h2>
        <p class="cta-subtitle">Prenez rendez-vous avec le Professeur Ramzi Moatemri pour une consultation privée et personnalisée.</p>
        <a asp-controller="Home" asp-action="Contact" class="luxury-pill-btn">PRENDRE RENDEZ-VOUS</a>
    </div>
</section>


