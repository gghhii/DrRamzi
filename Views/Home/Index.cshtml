<script>
    document.addEventListener("DOMContentLoaded", () => {
        const slides = document.querySelectorAll('.hero-slide');
        const dots = document.querySelectorAll('.slider-dot');
        let currentSlide = 0;
        const slideInterval = 8000;

        function updateSlider(index) {
            // Remove previous last-active before setting new ones
            slides.forEach(s => s.classList.remove('last-active'));
            
            // Find current active and set it to last-active so it stays visible during fade
            const currentActive = document.querySelector('.hero-slide.active');
            if(currentActive) {
                currentActive.classList.replace('active', 'last-active');
            }

            // Sync dots
            dots.forEach(d => d.classList.remove('active'));
            dots[index].classList.add('active');
            
            // Bring new slide to front and fade in
            slides[index].classList.add('active');
            currentSlide = index;
        }

        function nextSlide() {
            let next = (currentSlide + 1) % slides.length;
            updateSlider(next);
        }

        let autoSlide = setInterval(nextSlide, slideInterval);

        dots.forEach((dot, index) => {
            dot.addEventListener('click', () => {
                clearInterval(autoSlide);
                updateSlider(index);
                autoSlide = setInterval(nextSlide, slideInterval);
            });
        });

        // Modal Logic
        const modal = document.getElementById('clinicalModal');
        const closeBtn = document.querySelector('.modal-close-btn');
        const cmCases = document.querySelectorAll('.cm-case');

        const modalImgAnte = document.getElementById('modalImgAnte');
        const modalImgPost = document.getElementById('modalImgPost');
        const modalId = document.getElementById('modalId');
        const modalTitle = document.getElementById('modalTitle');
        const modalDesc = document.getElementById('modalDesc');
        const modalProtocol = document.getElementById('modalProtocol');

        cmCases.forEach(card => {
            card.addEventListener('click', () => {
                const id = card.querySelector('.cm-id').innerText;
                const title = card.querySelector('.cm-case-title').innerText;
                const protocol = card.querySelector('.cm-protocol-tag').innerText;
                const desc = card.querySelector('.cm-case-desc').innerText;
                const anteUrl = card.querySelector('.cm-ante .cm-img').style.backgroundImage.slice(5, -2);
                const postUrl = card.querySelector('.cm-post .cm-img').style.backgroundImage.slice(5, -2);

                modalImgAnte.src = anteUrl;
                modalImgPost.src = postUrl;
                modalId.innerText = id;
                modalTitle.innerText = title;
                modalDesc.innerText = desc;
                modalProtocol.innerText = protocol;

                modal.classList.add('active');
                document.body.style.overflow = 'hidden';
            });
        });

        closeBtn.addEventListener('click', () => {
            modal.classList.remove('active');
            document.body.style.overflow = '';
        });

        modal.addEventListener('click', (e) => {
            if (e.target === modal || e.target.classList.contains('modal-overlay-bg')) {
                modal.classList.remove('active');
                document.body.style.overflow = '';
            }
        });
    });
</script>



